 251); background-color: rgb(251, 251, 251);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: 400; color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: rgb(251, 251, 251);&quot;&gt;Enter data to update the reservation:&lt;/div&gt;&lt;div style=&quot;font-weight: 400; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(63, 63, 63), rgb(183, 183, 183));&quot;&gt;Check-in date (dd/MM/yyyy): &lt;/span&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;24/09/2016&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: 400; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(63, 63, 63), rgb(183, 183, 183));&quot;&gt;Check-out date (dd/MM/yyyy): &lt;/span&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;29/09/2016&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); background-color: rgb(251, 251, 251);&quot;&gt;&lt;b&gt;Error in reservation: Reservation dates for update must be future dates&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=21;verticalAlign=top;align=left;spacingLeft=10;spacingTop=-24;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" parent="31" vertex="1">
